{
  "name": "flaky",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0",
    "dev:poll": "WATCHPACK_POLLING=true next dev",
    "dev:clean": "npm run clean && next dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "rebuild": "npm run clean && npm run build",
    "start": "next start",
    "lint": "next lint",
    "cap:sync": "npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:dev": "node scripts/cap-dev-sync.cjs"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@upstash/redis": "^1.34.0",
    "libphonenumber-js": "^1.12.40",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "twilio": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "autoprefixer": "^10.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vercel": "^50.37.1"
  }
}
